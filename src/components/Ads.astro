---
// src/components/Ads.astro
const { type } = Astro.props;
---

<div class="ad-safe-container">
  <p style="font-size: 10px; color: gray; text-align: center; margin: 0;">Ads</p>
  <div class="ad-content">
    {type === 'horizontal' && (
      <script is:inline src="https://adm.shinobi.jp/o/ae858bf51ea81ba7e5d8c491dbc3d627" defer></script>
    )}
    {type === 'square' && (
      <script is:inline src="https://adm.shinobi.jp/o/c68c880288e59ed7ade0e94d250be6c9" defer></script>
    )}
    {type === 'vertical' && (
      <script is:inline src="https://adm.shinobi.jp/o/daba29522a811c8f83b60fcc4e941252" defer></script>
    )}
  </div>
</div>

<style>
  .ad-safe-container {
    width: 100%;
    overflow: hidden; /* これが重要！はみ出しをカット */
    margin: 1rem 0;
  }
  .ad-content {
    display: flex;
    justify-content: center;
    max-width: 100%;
  }
</style>
